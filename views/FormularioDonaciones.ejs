<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Formulario de Donación</title>
  <link rel="stylesheet" href="/styles/FormularioDonaciones.css">
</head>
<body>

<div class="formulario">
  <h1>Formulario de Donación</h1>

  <form id="formDonacion" class="contenedor" novalidate>

    <div class="seccion">
      <h2>Información Personal</h2>

      <label for="nombre">Nombre completo:</label>
      <input type="text" id="nombre" name="nombre" readonly placeholder="Ej. Juan Pérez" value="<%= user?.nombre || '' %>">
      <span class="error" id="errorNombre"></span>

      <label for="email">Correo electrónico:</label>
      <input type="email" id="email" name="email" readonly placeholder="Ej. correo@ejemplo.com" value="<%= user?.correo || '' %>">
      <span class="error" id="errorEmail"></span>
    </div>

    <div class="seccion">
      <h2>Donación Económica</h2>

      <label for="monto">Monto a donar:</label>
      <input type="text" id="monto" name="monto" placeholder="$0.00" inputmode="numeric">
      <span class="error" id="errorMonto"></span>

      <label>Método de pago:</label>
      <div class="checkbox-group">
        <label><input type="radio" name="metodoPago" value="tarjeta"> Tarjeta de crédito/débito</label>
        <label><input type="radio" name="metodoPago" value="transferencia"> Transferencia bancaria</label>
        <label><input type="radio" name="metodoPago" value="paypal"> PayPal</label>
        <label><input type="radio" name="metodoPago" value="otro"> Otro</label>
      </div>
      <span class="error" id="errorMetodoPago"></span>
    </div>

    <div class="seccion" id="seccionTarjeta" style="display: none;">
      <h2>Datos de Tarjeta</h2>

      <label for="nombreTarjeta">Nombre en la tarjeta:</label>
      <input type="text" id="nombreTarjeta" name="nombreTarjeta" placeholder="Nombre tal como aparece">
      <span class="error" id="errorNombreTarjeta"></span>

      <label for="numeroTarjeta">Número de tarjeta:</label>
      <input type="text" id="numeroTarjeta" name="numeroTarjeta" placeholder="Ingrese los 16 dígitos" maxlength="16" inputmode="numeric">
      <span class="error" id="errorNumeroTarjeta"></span>

      <label for="fechaVencimiento">Fecha de vencimiento:</label>
      <input type="month" id="fechaVencimiento" name="fechaVencimiento">
      <span class="error" id="errorFechaVencimiento"></span>

      <label for="cvv">Código de seguridad (CVV):</label>
      <input type="password" id="cvv" name="cvv" maxlength="4" placeholder="XXX">
      <span class="error" id="errorCvv"></span>
    </div>

    <div class="seccion">
      <h2>Donación de Materiales</h2>

      <label>Tipo de material:</label>
      <div class="checkbox-group">
        <label><input type="checkbox" name="material[]" value="comida"> Pienso / Comida húmeda</label>
        <label><input type="checkbox" name="material[]" value="mantas"> Mantas / Camas</label>
        <label><input type="checkbox" name="material[]" value="medicamentos"> Medicamentos / Material veterinario</label>
        <label><input type="checkbox" name="material[]" value="juguetes"> Juguetes / Correas</label>
      </div>

      <label for="materialOtro">Otro (especificar):</label>
      <textarea id="materialOtro" name="materialOtro" rows="3" placeholder="Describe otros materiales..."></textarea>
    </div>

  
    <div class="boton-contenedor">
  <button type="submit">Enviar Donación</button>
  <a href="/menu" class="boton-volver">Volver al Menú</a>
</div>


  </form>
</div>

<script>
  const form = document.getElementById('formDonacion');
  const metodoPagoRadios = document.querySelectorAll('input[name="metodoPago"]');
  const seccionTarjeta = document.getElementById('seccionTarjeta');

  metodoPagoRadios.forEach(radio => {
    radio.addEventListener('change', function() {
      seccionTarjeta.style.display = (this.value === 'tarjeta') ? 'block' : 'none';
    });
  });

  const numeroTarjeta = document.getElementById('numeroTarjeta');
  numeroTarjeta.addEventListener('input', function () {
    this.value = this.value.replace(/\D/g, '');
  });

  form.addEventListener('submit', function(event) {
    let valid = true;
    document.querySelectorAll('.error').forEach(span => span.textContent = '');

    const metodoPagoSeleccionado = document.querySelector('input[name="metodoPago"]:checked');
    if (!metodoPagoSeleccionado) {
      document.getElementById('errorMetodoPago').textContent = 'Seleccione un método de pago.';
      valid = false;
    }

    if (metodoPagoSeleccionado && metodoPagoSeleccionado.value === 'tarjeta') {
      if (numeroTarjeta.value.length !== 16) {
        document.getElementById('errorNumeroTarjeta').textContent = 'El número de tarjeta debe tener exactamente 16 dígitos.';
        valid = false;
      }
    }

    if (!valid) event.preventDefault();
  });
</script>

</body>
</html>
